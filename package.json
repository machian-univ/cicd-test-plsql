{
  "name": "pulsqual",
  "version": "1.0.0",
  "description": "Мультиагентная QAOps-система для тестирования и анализа деградации кода",
  "bin": {
    "pulsqual": "./dist/bin/pulsqual.js"
  },
  "main": "./dist/src/index.js",
  "type": "commonjs",
  "files": [
    "dist",
    "degradation_model.onnx"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); ['dist', 'dist/bin', 'dist/src'].forEach(d => { if(!fs.existsSync(d)) fs.mkdirSync(d, {recursive:true}); if(fs.existsSync('degradation_model.onnx')) fs.copyFileSync('degradation_model.onnx', d+'/degradation_model.onnx'); });\"",
    "prepare": "npm run build",
    "dev": "ts-node bin/pulsqual.ts",
    "start": "node dist/bin/pulsqual.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "execa": "^5.1.1",
    "inquirer": "^8.2.7",
    "js-yaml": "^4.1.0",
    "onnxruntime-node": "^1.18.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "overrides": {
    "semver": "^7.5.4",
    "word-wrap": "^1.2.4",
    "tough-cookie": "^4.1.3",
    "braces": "^3.0.3"
  }
}